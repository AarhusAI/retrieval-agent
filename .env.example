COMPOSE_PROJECT_NAME=retrieval-agent
COMPOSE_DOMAIN=retrieval.local.itkdev.dk

# Required — must match RAG_EXTERNAL_RETRIEVAL_API_KEY in Open WebUI
API_KEY=change-me

# Qdrant connection
QDRANT_URI=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=open-webui
QDRANT_MULTITENANCY=true

# Embedding — must match Open WebUI's RAG embedding config
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_API_BASE_URL=https://embed.itkdev.dk/v1
EMBEDDING_API_KEY=123456789
EMBEDDING_QUERY_PREFIX=query:

# Hybrid search (BM25 + vector fusion)
ENABLE_HYBRID_SEARCH=false
HYBRID_BM25_WEIGHT=0.3

# Cross-encoder reranking
ENABLE_RERANKING=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_API_BASE_URL=https://embed.itkdev.dk
RERANKER_API_KEY=
INITIAL_RETRIEVAL_MULTIPLIER=3

# Query generation from messages (linear pipeline; agentic pipeline uses system prompt)
ENABLE_QUERY_GENERATION=true
RETRIEVAL_QUERY_GENERATION_PROMPT_TEMPLATE_RAG="### Retningslinjer for søgning:\n- Basér forespørgsler **udelukkende på brugerens spørgsmål og informationsbehov**. Brug assistentens svar kun til kontekst og disambiguation (f.eks. til at forstå hvad
  \"det\", \"den anden\" refererer til).\n- Generér forespørgsler som naturlige sætninger der fanger den semantiske betydning af brugerens informationsbehov.\n- Omformuler samtale-referencer (\"det\", \"den anden\", \"hvad med\") til selvstændige,
  fuldstændige forespørgsler.\n- Hver forespørgsel skal dække en forskellig vinkel for at maksimere dækningen af relevante dokumenter.\n- Hvis brugerens besked tydeligt ikke kræver dokumentsøgning (f.eks. hilsner), søg med en tom liste.\n- Svar på
  samtalens primære sprog; brug dansk som standard."

# Agentic RAG
ENABLE_AGENTIC_RAG=false
AGENT_MODEL=gpt-4o-mini
AGENT_API_BASE_URL=http://litellm:4000/v1
AGENT_API_KEY=
AGENT_MAX_ITERATIONS=3

# Server
HOST=0.0.0.0
PORT=8000
